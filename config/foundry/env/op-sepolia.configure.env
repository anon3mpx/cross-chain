# ConfigureAll env for OP Sepolia (chainId 11155420)
# This file configures contracts ON OP.
#
# Address direction rules:
# - Local (OP) addresses: RECEIVER_V1, *_ADAPTER, RECEIVER_APPROVED_CALLER_*
# - Remote (Base) addresses: *_ROUTE_RECEIVER, *_SOURCE_PEER_ADDRESS

RPC_URL=https://sepolia.optimism.io
DEPLOYER_PRIVATE_KEY=

# Core local contracts (OP)
PLUGIN_REGISTRY=0x5e8297763d7448718917b16b88347766b0920af9
ROUTER_V1=0x78546a4ace4529582d7ddf4356baf110fa343701
RECEIVER_V1=0xbc4cbd47e7bf5eec5ede5f3a805c8dcc20d843a0

# Rail plugins on OP
RAIL_PLUGIN_CCTP=0xb1b9c30c08c37af935cda3be0e3f124a580cb1a6
RAIL_PLUGIN_CCTP_FAST=0x6a790bf1991d3a53b81bb9316fb3b3e8217c5699
RAIL_PLUGIN_AXELAR=0xa73776c0aae79382d8003b1fc7648b5ab32889d0
RAIL_PLUGIN_LAYERZERO=0x55cc592be7e49c4020e67a895fee9474c7d71dbc
RAIL_PLUGIN_THORCHAIN=0x0000000000000000000000000000000000000000

# Optional swap plugin registration (unused)
SWAP_PLUGIN_EMPSEAL=0x0000000000000000000000000000000000000000
SWAP_PLUGIN_UNIV2=0x0000000000000000000000000000000000000000
SWAP_PLUGIN_UNIV3=0x0000000000000000000000000000000000000000

# ReceiverV1 approvals on OP (LOCAL adapter addresses only)
RECEIVER_APPROVED_CALLER_1=0xd8016e376e15b20fc321a37fd69dc42cfdf951bb  # OP AxelarReceiverAdapter
RECEIVER_APPROVED_CALLER_2=0x96e67d7295a0bca3e57c7de9a1a9bf28fd56ffdc  # OP LayerZeroReceiverAdapter
RECEIVER_APPROVED_CALLER_3=0x0000000000000000000000000000000000000000
RECEIVER_APPROVED_CALLER_4=0x0000000000000000000000000000000000000000
RECEIVER_APPROVED_CALLER_5=0x0000000000000000000000000000000000000000

# Optional sections off for this file
ROUTER_SET_FEE_RECIPIENT=false
PAYMASTER_SET_SIGNER=false
PAYMASTER_SET_TOKEN_RATE=false
THOR_SET_VAULT=false
THOR_SET_ROUTER=false

# CCTP routes (OP -> Base)
# destination caller is restricted to your relay EOA on destination.
CCTP_SET_ROUTE=true
CCTP_PLUGIN=0xb1b9c30c08c37af935cda3be0e3f124a580cb1a6
CCTP_ROUTE_CHAIN_ID=84532
CCTP_ROUTE_DOMAIN=6
CCTP_ROUTE_RECEIVER=0x8fb0438d0799c52920515b31310f53452c33e066
CCTP_ROUTE_CALLER=0x05F8cC8753D90d67DBB8c02118440b8283F941c9

# CCTP Fast routes (OP -> Base)
CCTP_FAST_SET_ROUTE=true
CCTP_FAST_PLUGIN=0x6a790bf1991d3a53b81bb9316fb3b3e8217c5699
CCTP_FAST_ROUTE_CHAIN_ID=84532
CCTP_FAST_ROUTE_DOMAIN=6
CCTP_FAST_ROUTE_RECEIVER=0x8fb0438d0799c52920515b31310f53452c33e066
CCTP_FAST_ROUTE_CALLER=0x05F8cC8753D90d67DBB8c02118440b8283F941c9
CCTP_FAST_MAX_FEE_BPS_CAP=100

# ----------------------------
# Outbound routes: OP -> Base
# ----------------------------

# Axelar route on OP plugin:
# destination receiver must be Base AxelarReceiverAdapter.
AXELAR_SET_ROUTE=true
AXELAR_PLUGIN=0xa73776c0aae79382d8003b1fc7648b5ab32889d0
AXELAR_ROUTE_CHAIN_ID=84532
AXELAR_ROUTE_NAME=base-sepolia
AXELAR_ROUTE_RECEIVER=0x5fd1f6db09c8d64f2230415d8f0f9e87f5462fa3
AXELAR_ROUTE_TOKEN_ID=0x4d2fdc120be87ecf5661b7a75144d5d4b507b525eeb8c9c85c346a255e3b9663

# LayerZero route on OP plugin:
# destination receiver must be Base LayerZeroReceiverAdapter.
LZ_SET_ROUTE=true
LZ_PLUGIN=0x55cc592be7e49c4020e67a895fee9474c7d71dbc
LZ_ROUTE_CHAIN_ID=84532
LZ_ROUTE_EID=40245
LZ_ROUTE_RECEIVER=0x4e5d1ff12514cc396aa37757878a02433887ede0
LZ_ROUTE_OPTIONS=0x00030100110100000000000000000000000000030d4001001303000000000000000000000000000000061a80

# -------------------------------------
# Inbound trust config: Base -> OP side
# -------------------------------------

# Axelar adapter trust on OP local adapter:
# source address is Base AxelarRailPlugin.
AXELAR_ADAPTER_SET_TRUSTED_SOURCE=true
AXELAR_ADAPTER=0xd8016e376e15b20fc321a37fd69dc42cfdf951bb
AXELAR_SOURCE_CHAIN=base-sepolia
AXELAR_SOURCE_ADDRESS=0xd00e7ce0ac312138de62610ed950e814e12d3f89
AXELAR_SOURCE_TRUSTED=true
AXELAR_TRUSTED_TOKEN_ID=0x4d2fdc120be87ecf5661b7a75144d5d4b507b525eeb8c9c85c346a255e3b9663
AXELAR_TRUSTED_TOKEN=0x2f2A9DbFd8c503a0aC56413B774e39030df85331

# LayerZero peer trust on OP local adapter:
# source peer address is Base LayerZeroRailPlugin.
LZ_ADAPTER_SET_TRUSTED_PEER=true
LZ_ADAPTER=0x96e67d7295a0bca3e57c7de9a1a9bf28fd56ffdc
LZ_SOURCE_EID=40245
LZ_SOURCE_PEER_ADDRESS=0x05c5a9dff519bbb26e206d02e90aa9ca5105a327

# LayerZero OFT peer on OP:
# peer must be Base OFT for dst eid 40245.
LZ_OFT_SET_PEER=true
LZ_OFT=0xC1d9A1f64291CF47e703eab6b27fA0660cAE7324
LZ_OFT_PEER_EID=40245
LZ_OFT_PEER_ADDRESS=0x1500116D88B6583E63E2Fa9D4199f2edDf72149b
