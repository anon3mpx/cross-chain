# ConfigureAll env for Base Sepolia (chainId 84532)
# This file configures contracts ON Base.
#
# Address direction rules:
# - Local (Base) addresses: RECEIVER_V1, *_ADAPTER, RECEIVER_APPROVED_CALLER_*
# - Remote (OP) addresses: *_ROUTE_RECEIVER, *_SOURCE_PEER_ADDRESS

RPC_URL=https://sepolia.base.org
DEPLOYER_PRIVATE_KEY=

# Core local contracts (Base)
PLUGIN_REGISTRY=0x84c05502ee5ee8cb2ef43273f300439cad0c4020
ROUTER_V1=0x6a68e37f678c4eb104372ed4b6ac97bd0ddef30a
RECEIVER_V1=0x8fb0438d0799c52920515b31310f53452c33e066

# Rail plugins on Base
RAIL_PLUGIN_CCTP=0xae72a52f4a6b36d65cc971df9fdeffa07ab5db5e
RAIL_PLUGIN_CCTP_FAST=0xacb6a28814a7baea27cec106e086ab0bdda37f9c
RAIL_PLUGIN_AXELAR=0xd00e7ce0ac312138de62610ed950e814e12d3f89
RAIL_PLUGIN_LAYERZERO=0x05c5a9dff519bbb26e206d02e90aa9ca5105a327
RAIL_PLUGIN_THORCHAIN=0x0000000000000000000000000000000000000000

# Optional swap plugin registration (unused)
SWAP_PLUGIN_EMPSEAL=0x0000000000000000000000000000000000000000
SWAP_PLUGIN_UNIV2=0x0000000000000000000000000000000000000000
SWAP_PLUGIN_UNIV3=0x0000000000000000000000000000000000000000

# ReceiverV1 approvals on Base (LOCAL adapter addresses only)
RECEIVER_APPROVED_CALLER_1=0x5fd1f6db09c8d64f2230415d8f0f9e87f5462fa3  # Base AxelarReceiverAdapter
RECEIVER_APPROVED_CALLER_2=0x4e5d1ff12514cc396aa37757878a02433887ede0  # Base LayerZeroReceiverAdapter
RECEIVER_APPROVED_CALLER_3=0x0000000000000000000000000000000000000000
RECEIVER_APPROVED_CALLER_4=0x0000000000000000000000000000000000000000
RECEIVER_APPROVED_CALLER_5=0x0000000000000000000000000000000000000000

# Optional sections off for this file
ROUTER_SET_FEE_RECIPIENT=false
PAYMASTER_SET_SIGNER=false
PAYMASTER_SET_TOKEN_RATE=false
THOR_SET_VAULT=false
THOR_SET_ROUTER=false

# CCTP routes (Base -> OP)
# destination caller is restricted to your relay EOA on destination.
CCTP_SET_ROUTE=true
CCTP_PLUGIN=0xae72a52f4a6b36d65cc971df9fdeffa07ab5db5e
CCTP_ROUTE_CHAIN_ID=11155420
CCTP_ROUTE_DOMAIN=2
CCTP_ROUTE_RECEIVER=0xbc4cbd47e7bf5eec5ede5f3a805c8dcc20d843a0
CCTP_ROUTE_CALLER=0x05F8cC8753D90d67DBB8c02118440b8283F941c9

# CCTP Fast routes (Base -> OP)
CCTP_FAST_SET_ROUTE=true
CCTP_FAST_PLUGIN=0xacb6a28814a7baea27cec106e086ab0bdda37f9c
CCTP_FAST_ROUTE_CHAIN_ID=11155420
CCTP_FAST_ROUTE_DOMAIN=2
CCTP_FAST_ROUTE_RECEIVER=0xbc4cbd47e7bf5eec5ede5f3a805c8dcc20d843a0
CCTP_FAST_ROUTE_CALLER=0x05F8cC8753D90d67DBB8c02118440b8283F941c9
CCTP_FAST_MAX_FEE_BPS_CAP=100

# ----------------------------
# Outbound routes: Base -> OP
# ----------------------------

# Axelar route on Base plugin:
# destination receiver must be OP AxelarReceiverAdapter.
AXELAR_SET_ROUTE=true
AXELAR_PLUGIN=0xd00e7ce0ac312138de62610ed950e814e12d3f89
AXELAR_ROUTE_CHAIN_ID=11155420
AXELAR_ROUTE_NAME=optimism-sepolia
AXELAR_ROUTE_RECEIVER=0xd8016e376e15b20fc321a37fd69dc42cfdf951bb
AXELAR_ROUTE_TOKEN_ID=0x4d2fdc120be87ecf5661b7a75144d5d4b507b525eeb8c9c85c346a255e3b9663

# LayerZero route on Base plugin:
# destination receiver must be OP LayerZeroReceiverAdapter.
LZ_SET_ROUTE=true
LZ_PLUGIN=0x05c5a9dff519bbb26e206d02e90aa9ca5105a327
LZ_ROUTE_CHAIN_ID=11155420
LZ_ROUTE_EID=40232
LZ_ROUTE_RECEIVER=0x96e67d7295a0bca3e57c7de9a1a9bf28fd56ffdc
LZ_ROUTE_OPTIONS=0x00030100110100000000000000000000000000030d4001001303000000000000000000000000000000061a80

# -------------------------------------
# Inbound trust config: OP -> Base side
# -------------------------------------

# Axelar adapter trust on Base local adapter:
# source address is OP AxelarRailPlugin.
AXELAR_ADAPTER_SET_TRUSTED_SOURCE=true
AXELAR_ADAPTER=0x5fd1f6db09c8d64f2230415d8f0f9e87f5462fa3
AXELAR_SOURCE_CHAIN=optimism-sepolia
AXELAR_SOURCE_ADDRESS=0xa73776c0aae79382d8003b1fc7648b5ab32889d0
AXELAR_SOURCE_TRUSTED=true
AXELAR_TRUSTED_TOKEN_ID=0x4d2fdc120be87ecf5661b7a75144d5d4b507b525eeb8c9c85c346a255e3b9663
AXELAR_TRUSTED_TOKEN=0x2f2A9DbFd8c503a0aC56413B774e39030df85331

# LayerZero peer trust on Base local adapter:
# source peer address is OP LayerZeroRailPlugin.
LZ_ADAPTER_SET_TRUSTED_PEER=true
LZ_ADAPTER=0x4e5d1ff12514cc396aa37757878a02433887ede0
LZ_SOURCE_EID=40232
LZ_SOURCE_PEER_ADDRESS=0x55cc592be7e49c4020e67a895fee9474c7d71dbc

# LayerZero OFT peer on Base:
# peer must be OP OFT for dst eid 40232.
LZ_OFT_SET_PEER=true
LZ_OFT=0x1500116D88B6583E63E2Fa9D4199f2edDf72149b
LZ_OFT_PEER_EID=40232
LZ_OFT_PEER_ADDRESS=0xC1d9A1f64291CF47e703eab6b27fA0660cAE7324
