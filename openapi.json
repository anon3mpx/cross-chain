{
  "openapi": "3.0.3",
  "info": {
    "title": "Empx Cross-chain VPS API",
    "version": "1.0.0",
    "description": "OpenAPI definition for non-partner VPS HTTP endpoints exposed by StatusAPI and AdminAPI. Endpoints under /partner are intentionally excluded."
  },
  "servers": [
    {
      "url": "http://localhost:8787",
      "description": "Default local VPS API host/port"
    }
  ],
  "tags": [
    {
      "name": "Public",
      "description": "Unauthenticated quote, intent, and health endpoints"
    },
    {
      "name": "Admin",
      "description": "Admin endpoints protected by x-admin-key"
    }
  ],
  "paths": {
    "/quote": {
      "post": {
        "tags": [
          "Public"
        ],
        "operationId": "createOfferSetQuote",
        "summary": "Create quote offers",
        "description": "Returns an offer set and optionally a legacy top-level quote snapshot.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote offers created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteOfferSetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or no available route",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Temporary quote/unavailable condition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/quote/select": {
      "post": {
        "tags": [
          "Public"
        ],
        "operationId": "selectQuoteOffer",
        "summary": "Select offer and build integration",
        "description": "Selects one offer from an offer set and returns intentId, quote, and executable integration payload.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteSelectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Offer selected and integration prepared",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteSelectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid selection payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Offer or offer set unavailable/expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Selected offer unavailable with fallback candidates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OfferUnavailableResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Integration/calldata generation unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/intent/{id}": {
      "get": {
        "tags": [
          "Public"
        ],
        "operationId": "getIntentStatus",
        "summary": "Get intent status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Intent ID",
            "schema": {
              "$ref": "#/components/schemas/IntentId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Intent status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntentStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Intent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Status backend unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/intent/{id}/submitted": {
      "post": {
        "tags": [
          "Public"
        ],
        "operationId": "markIntentSubmitted",
        "summary": "Mark intent as submitted",
        "description": "Requires a signed wallet message and source transaction hash.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/IntentId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IntentSubmittedRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Intent updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntentStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "404": {
            "description": "Intent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "409": {
            "description": "Intent state conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/intent/{id}/cancel": {
      "post": {
        "tags": [
          "Public"
        ],
        "operationId": "cancelIntent",
        "summary": "Cancel intent",
        "description": "Cancels a quote-stage intent or records wallet-level cancellation for submitted intents.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/IntentId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IntentCancelRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Intent updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntentStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "404": {
            "description": "Intent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "409": {
            "description": "Cancellation conflict (wallet replacement tx flow)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/intent/{id}/refund": {
      "post": {
        "tags": [
          "Public"
        ],
        "operationId": "requestIntentRefund",
        "summary": "Request refund review",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/IntentId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IntentRefundRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Refund review requested",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefundRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "404": {
            "description": "Intent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "409": {
            "description": "Refund review not allowed for current intent status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Public"
        ],
        "operationId": "getHealth",
        "summary": "Get API health",
        "responses": {
          "200": {
            "description": "Health payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/intents/{id}/refund": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "adminUpdateIntentRefund",
        "summary": "Admin refund case update",
        "description": "Updates refund case fields for an intent. Requires x-admin-key header.",
        "parameters": [
          {
            "name": "x-admin-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/IntentId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminRefundUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund case updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminRefundUpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid admin payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized admin key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorWithMessageResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Address": {
        "type": "string",
        "description": "Address-like token/user field accepted by the VPS."
      },
      "BigIntString": {
        "type": "string",
        "pattern": "^[0-9]+$",
        "description": "Unsigned integer encoded as a base-10 string."
      },
      "Bytes": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]*$"
      },
      "Bytes32": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]{64}$"
      },
      "IntentId": {
        "$ref": "#/components/schemas/Bytes32"
      },
      "Rail": {
        "type": "string",
        "enum": [
          "CCTP",
          "CCTP_FAST",
          "AXELAR",
          "LAYERZERO",
          "VIA_LABS",
          "WORMHOLE",
          "THORCHAIN"
        ]
      },
      "RailType": {
        "type": "string",
        "enum": [
          "messaging",
          "liquidity"
        ]
      },
      "SettlementToken": {
        "type": "string",
        "enum": [
          "USDC",
          "USDT",
          "ETH",
          "BTC",
          "SOL"
        ]
      },
      "IntentStatus": {
        "type": "string",
        "enum": [
          "CREATED",
          "QUOTED",
          "CANCELLED",
          "SUBMITTED",
          "IN_TRANSIT",
          "DESTINATION_RECEIVED",
          "SETTLED",
          "STUCK",
          "RECOVERING",
          "FAILED"
        ]
      },
      "RefundCaseStatus": {
        "type": "string",
        "enum": [
          "REQUESTED",
          "UNDER_REVIEW",
          "APPROVED",
          "REJECTED",
          "PROCESSING",
          "COMPLETED"
        ]
      },
      "RefundCustodyLocation": {
        "type": "string",
        "enum": [
          "UNKNOWN",
          "ROUTER",
          "RECEIVER",
          "AXELAR_ADAPTER",
          "LAYERZERO_ADAPTER",
          "THORCHAIN_ROUTER",
          "CCTP_PROTOCOL",
          "AXELAR_PROTOCOL",
          "LAYERZERO_PROTOCOL",
          "EXTERNAL_PROTOCOL"
        ]
      },
      "RefundResolutionKind": {
        "type": "string",
        "enum": [
          "ONCHAIN_RESCUE",
          "OFFCHAIN_COMPENSATION",
          "PROTOCOL_RECOVERY"
        ]
      },
      "QuoteRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tokenIn",
          "tokenOut",
          "amountIn",
          "srcChainId",
          "dstChainId",
          "userAddress"
        ],
        "properties": {
          "tokenIn": {
            "$ref": "#/components/schemas/Address"
          },
          "tokenOut": {
            "$ref": "#/components/schemas/Address"
          },
          "amountIn": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/BigIntString"
              },
              {
                "type": "integer",
                "minimum": 1
              }
            ]
          },
          "srcChainId": {
            "type": "integer"
          },
          "dstChainId": {
            "type": "integer"
          },
          "userAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "nativeDstAddress": {
            "type": "string"
          },
          "urgency": {
            "type": "string",
            "enum": [
              "fast",
              "normal"
            ],
            "default": "normal"
          }
        }
      },
      "RouteAssetRef": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "canonicalAssetId",
          "providerAssetId",
          "decimals",
          "assetKind"
        ],
        "properties": {
          "canonicalAssetId": {
            "type": "string"
          },
          "providerAssetId": {
            "type": "string"
          },
          "tokenAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "srcTokenAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "dstTokenAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "decimals": {
            "type": "integer"
          },
          "assetKind": {
            "type": "string"
          },
          "assetStandard": {
            "type": "string"
          }
        }
      },
      "QuoteResult": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "intentId",
          "srcChainId",
          "dstChainId",
          "tokenIn",
          "tokenOut",
          "amountIn",
          "estimatedOut",
          "minAmountOut",
          "minSrcSwapOut",
          "feeAmountUSD",
          "feeAmountToken",
          "rail",
          "railType",
          "settlementToken",
          "etaSeconds",
          "expiresAt",
          "railPluginId",
          "railData",
          "swapPluginIdSrc",
          "swapPluginIdDst",
          "swapDataSrc",
          "swapDataDst"
        ],
        "properties": {
          "intentId": {
            "$ref": "#/components/schemas/IntentId"
          },
          "srcChainId": {
            "type": "integer"
          },
          "dstChainId": {
            "type": "integer"
          },
          "tokenIn": {
            "$ref": "#/components/schemas/Address"
          },
          "tokenOut": {
            "$ref": "#/components/schemas/Address"
          },
          "amountIn": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "estimatedOut": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "minAmountOut": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "minSrcSwapOut": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "feeAmountUSD": {
            "type": "number"
          },
          "feeAmountToken": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "rail": {
            "$ref": "#/components/schemas/Rail"
          },
          "railType": {
            "$ref": "#/components/schemas/RailType"
          },
          "settlementToken": {
            "$ref": "#/components/schemas/SettlementToken"
          },
          "routeAsset": {
            "$ref": "#/components/schemas/RouteAssetRef"
          },
          "settlementAssetId": {
            "$ref": "#/components/schemas/Bytes32"
          },
          "expectedDstSettlementToken": {
            "$ref": "#/components/schemas/Address"
          },
          "expectedDstSettlementAssetId": {
            "$ref": "#/components/schemas/Bytes32"
          },
          "minSettlementAmount": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "dstGasLimit": {
            "type": "integer"
          },
          "etaSeconds": {
            "type": "integer"
          },
          "expiresAt": {
            "type": "integer"
          },
          "railPluginId": {
            "$ref": "#/components/schemas/Bytes32"
          },
          "railData": {
            "$ref": "#/components/schemas/Bytes"
          },
          "swapPluginIdSrc": {
            "$ref": "#/components/schemas/Bytes32"
          },
          "swapPluginIdDst": {
            "$ref": "#/components/schemas/Bytes32"
          },
          "swapDataSrc": {
            "$ref": "#/components/schemas/Bytes"
          },
          "swapDataDst": {
            "$ref": "#/components/schemas/Bytes"
          },
          "nativeDstAddress": {
            "type": "string"
          }
        }
      },
      "OfferEconomics": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "providerFeeUSD": {
            "type": "number"
          },
          "protocolFeeUSD": {
            "type": "number"
          },
          "sourceGasUSD": {
            "type": "number"
          },
          "destinationGasUSD": {
            "type": "number"
          },
          "outboundFeeUSD": {
            "type": "number"
          },
          "settlementTimeSeconds": {
            "type": "number"
          }
        }
      },
      "RailOffer": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "offerId",
          "rail",
          "railType",
          "srcChainId",
          "dstChainId",
          "tokenIn",
          "tokenOut",
          "amountIn",
          "estimatedOut",
          "minAmountOut",
          "expiresAt"
        ],
        "properties": {
          "offerId": {
            "$ref": "#/components/schemas/IntentId"
          },
          "offerType": {
            "type": "string"
          },
          "rail": {
            "$ref": "#/components/schemas/Rail"
          },
          "railType": {
            "$ref": "#/components/schemas/RailType"
          },
          "srcChainId": {
            "type": "integer"
          },
          "dstChainId": {
            "type": "integer"
          },
          "tokenIn": {
            "$ref": "#/components/schemas/Address"
          },
          "tokenOut": {
            "$ref": "#/components/schemas/Address"
          },
          "amountIn": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "estimatedOut": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "minAmountOut": {
            "$ref": "#/components/schemas/BigIntString"
          },
          "expiresAt": {
            "type": "integer"
          },
          "deliveryShape": {
            "type": "string"
          },
          "executionMode": {
            "type": "string",
            "enum": [
              "router_intent",
              "provider_direct"
            ]
          },
          "routeAsset": {
            "$ref": "#/components/schemas/RouteAssetRef"
          },
          "sourceSettlementAsset": {
            "$ref": "#/components/schemas/RouteAssetRef"
          },
          "destinationSettlementAsset": {
            "$ref": "#/components/schemas/RouteAssetRef"
          },
          "economics": {
            "$ref": "#/components/schemas/OfferEconomics"
          },
          "execution": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "OfferSet": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "offerSetId",
          "expiresAt",
          "offers"
        ],
        "properties": {
          "offerSetId": {
            "$ref": "#/components/schemas/IntentId"
          },
          "expiresAt": {
            "type": "integer"
          },
